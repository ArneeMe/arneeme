---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900 font-sans">
    <slot name="header" />
    <main class="max-w-3xl mx-auto px-4 py-8">
      <slot />
    </main>
    <footer class="max-w-3xl mx-auto px-4 py-8 text-sm text-gray-500 border-t border-gray-200 mt-8">
      <p>&copy; {new Date().getFullYear()} Arne Natskår</p>
    </footer>
  </body>
</html>
