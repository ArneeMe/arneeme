---
import '../styles/global.css';

interface Props {
  title: string;
  centered?: boolean;
}

const { title, centered = false } = Astro.props;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class:list={["min-h-screen bg-stone-50 text-gray-800 font-sans", centered && "flex items-center justify-center"]}>
    {!centered && <slot name="header" />}
    <main class:list={[!centered && "max-w-2xl mx-auto px-6 py-12"]}>
      <slot />
    </main>
    {!centered && (
      <footer class="max-w-2xl mx-auto px-6 py-10 text-xs tracking-wide text-gray-400 border-t border-gray-200/60 mt-16">
        <p>&copy; {new Date().getFullYear()} Arne Natskår</p>
      </footer>
    )}
  </body>
</html>
