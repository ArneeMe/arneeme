---
import '../styles/desktop.css';
import '../styles/mobile.css';
import '98.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const site = Astro.site ?? new URL('https://arnee.me');
const pageUrl = new URL(Astro.url.pathname, site);
const ogImage = new URL('/og-image.png', site);
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Arne Natskårs personlige hjemmeside – et Windows 95-skrivebord i nettleseren med små apper, spill og verktøy."
    />
    <meta name="theme-color" content="#008080" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Et Windows 95-skrivebord i nettleseren – med små apper, spill og verktøy."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl.href} />
    <meta property="og:image" content={ogImage.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/icons/computer.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
