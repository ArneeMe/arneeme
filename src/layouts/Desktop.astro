---
import '../styles/desktop.css';
import '98.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/icons/computer.svg" />
  </head>
  <body>
    <slot />

    <div class="mobile-gate">
      <h2>🖥️ Krever skrivebord</h2>
      <p>
        Dette nettstedet er en Windows 95-skrivebordsopplevelse — det
        ser best ut på en større skjerm.
      </p>
      <p style="margin-top: 12px;">
        <a href="https://github.com/ArneeMe">Se GitHub-profilen min →</a>
      </p>
    </div>
  </body>
</html>
