---
import '../styles/desktop.css';
import '../styles/mobile.css';
import '98.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/icons/computer.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
