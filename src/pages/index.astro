---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Arne Natskår" centered>
  <div class="flex flex-col items-center gap-5 text-center px-4">
    <img
      src="/profile.png"
      alt="Arne Natskår"
      class="w-28 h-28 rounded-full object-cover grayscale"
    />
    <div>
      <h1 class="text-3xl font-semibold tracking-tight">Arne Natskår</h1>
      <p class="text-gray-400 mt-1 text-sm tracking-wide uppercase">Security Developer</p>
    </div>
    <nav class="flex gap-8 text-sm text-gray-500">
      <a href="/code" class="hover:text-gray-900 transition-colors">Prosjekter</a>
      <a href="/contact" class="hover:text-gray-900 transition-colors">Kontakt</a>
      <a href="https://github.com/ArneeMe" class="hover:text-gray-900 transition-colors">GitHub</a>
    </nav>
  </div>
</Layout>
