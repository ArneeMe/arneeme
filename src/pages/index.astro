---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Arne Natskår" centered>
  <div class="flex flex-col items-center gap-8 text-center px-6">
    <img
      src="/profile.png"
      alt="Arne Natskår"
      class="w-32 h-32 rounded-full object-cover grayscale ring-1 ring-gray-200 shadow-sm"
    />
    <div>
      <h1 class="text-3xl font-semibold tracking-tight text-gray-900">Arne Natskår</h1>
      <p class="text-gray-400 mt-2 text-xs tracking-widest uppercase">Security Developer</p>
    </div>
    <nav class="flex gap-8 text-sm text-gray-400">
      <a href="/code" class="hover:text-gray-800 transition-colors duration-200">Prosjekter</a>
      <a href="/contact" class="hover:text-gray-800 transition-colors duration-200">Kontakt</a>
      <a href="https://github.com/ArneeMe" class="hover:text-gray-800 transition-colors duration-200">GitHub</a>
    </nav>
  </div>
</Layout>
