---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const colors = [
  '#fce4b3', '#fcd37b', '#fcc421', '#fcbc14',
  '#93cbd3', '#1fa7b2', '#0494a4', '#048c9c',
];
---

<Layout title="Farger - Arne Natskår">
  <Header slot="header" />

  <h2 class="text-xl font-semibold mb-4">Farger til echo!</h2>
  <div class="flex flex-wrap gap-3">
    {colors.map((c) => (
      <div
        class="w-24 h-24 flex items-center justify-center text-white font-bold text-sm rounded"
        style={`background-color: ${c};`}
      >
        {c}
      </div>
    ))}
  </div>
</Layout>
